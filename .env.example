# PayChangu configuration — copy this file to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored). On Netlify, set these same
# variables under Site settings -> Environment variables instead.

# Your PayChangu SECRET key (required). Used server-side only.
#   Test mode:  sec-test-xxxxxxxxxxxxxxxxxxxxxxxx
#   Live mode:  sec-live-xxxxxxxxxxxxxxxxxxxxxxxx
PAYCHANGU_SECRET_KEY=

# Your PayChangu PUBLIC key (optional). Not used by the current server-side
# Standard Checkout flow; keep it only if you later add inline/JS checkout.
PAYCHANGU_PUBLIC_KEY=

# Currency for charges. PayChangu supports MWK or USD.
PAYCHANGU_CURRENCY=MWK

# Optional. Public base URL used to build the success/failure redirect links.
# Leave blank to auto-detect from the incoming request (works on Netlify).
# Set it only to force a specific domain, e.g. https://futurelifediagnostics.com
SITE_URL=

# Webhook secret from PayChangu Dashboard -> Settings -> API & Webhooks.
# Used to verify the "Signature" header (HMAC SHA-256) on incoming webhooks.
PAYCHANGU_WEBHOOK_SECRET=

# --- Booking records: Google Sheets via Apps Script web app ---
# See apps-script/sheet-logger.gs for setup. SHEETS_TOKEN must match the
# TOKEN value inside that script.
SHEETS_WEBHOOK_URL=
SHEETS_TOKEN=

# --- Email notifications: Resend (https://resend.com) ---
RESEND_API_KEY=
# Verified sender, e.g. "Future-Life Diagnostics <bookings@futurelifediagnostics.com>"
MAIL_FROM=
# Where new-booking alerts are sent (the lab's inbox).
LAB_NOTIFY_EMAIL=

# --- WhatsApp alert to the lab via CallMeBot (free) ---
# Register the lab's WhatsApp number at https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Phone in international format without "+", e.g. 265980855554
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
