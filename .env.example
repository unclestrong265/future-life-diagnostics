# PayChangu configuration — copy this file to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored). On Netlify, set these same
# variables under Site settings -> Environment variables instead.

# Your PayChangu SECRET key.
#   Test mode:  sec-test-xxxxxxxxxxxxxxxxxxxxxxxx
#   Live mode:  sec-live-xxxxxxxxxxxxxxxxxxxxxxxx
PAYCHANGU_SECRET_KEY=

# Currency for charges. PayChangu supports MWK or USD.
PAYCHANGU_CURRENCY=MWK

# Optional. Public base URL used to build the success/failure redirect links.
# Leave blank to auto-detect from the incoming request (works on Netlify).
# Set it only to force a specific domain, e.g. https://futurelifediagnostics.com
SITE_URL=
